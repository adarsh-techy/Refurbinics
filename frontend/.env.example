# Copy this file to .env and point it at your backend. .env is gitignored —
# never commit real values here (this one holds no secrets, just a URL, but
# it does differ per machine/environment).

# Base URL of the backend API, including the /api prefix. Vite only exposes
# env vars prefixed with VITE_ to client-side code (see src/services/api-client.js)
# and it's baked into the build at build time — changing it means rebuilding,
# not just restarting the server.
#   - Local dev on this machine only:        https://localhost:5443/api
#   - Local dev, testing from a phone/LAN:   https://<your-lan-ip>:5443/api
#   - Production:                             https://<your-backend-domain>/api
VITE_API_URL=https://localhost:5443/api
