# Copy this file to .env and fill in real values. .env is gitignored — never
# commit real secrets (JWT_SECRET, DB_PASSWORD) to the repo.

# ── Server ──────────────────────────────────────────────────────────────
# Port the plain HTTP server listens on.
PORT=5000
# Port the HTTPS server listens on. The HTTPS listener only starts if both
# backend/certs/key.pem and backend/certs/cert.pem exist (see server.js) —
# they're a self-signed dev cert so the QR-scanner's camera access works
# over a LAN origin, which browsers otherwise block on plain http. If TLS is
# terminated upstream instead (reverse proxy, load balancer, hosting
# platform), omit the certs and this var and the API runs HTTP-only.
HTTPS_PORT=5443
# development | production. In development, CORS allows any
# http(s)://<host>:5173 origin (so a phone on the LAN can reach the Vite dev
# server) and morgan logs the concise "dev" format. In production, CORS is
# locked to the single CLIENT_URL below and morgan switches to "combined".
NODE_ENV=development

# ── PostgreSQL ──────────────────────────────────────────────────────────
# Managed providers (Render/Railway/Supabase/Neon/etc.) give you a single
# connection string — set DATABASE_URL to that and leave the DB_* vars
# below unset; db.js prefers DATABASE_URL when present, and always connects
# with ssl on for it (required by these providers). For a plain local/self-
# hosted Postgres with no DATABASE_URL, the discrete DB_* vars below are
# used instead, with no ssl.
# DATABASE_URL=postgres://user:password@host:port/dbname

DB_HOST=localhost
DB_PORT=5432
DB_NAME=refurbinics
DB_USER=postgres
DB_PASSWORD=change_this_password

# ── Auth ────────────────────────────────────────────────────────────────
# Signs and verifies login JWTs. MUST be a long random value in production
# — anyone who has it can forge a super_admin token. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d

# ── CORS ────────────────────────────────────────────────────────────────
# The deployed frontend's exact origin(s) (scheme + host + port, no
# trailing slash) — comma-separated if there's more than one, e.g.
# https://refurbinics.vercel.app,https://admin.refurbinics.com. Only
# enforced when NODE_ENV=production; in development any port-5173 origin is
# allowed instead (see above), so this value is unused locally. Any
# https://refurbinics*.vercel.app origin (Vercel's per-branch/per-deploy
# preview URLs) is always allowed in production too, regardless of this
# list — see app.js.
CLIENT_URL=http://localhost:5173
