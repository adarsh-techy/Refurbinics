# One-time setup on the VPS: `cp .env.example .env`, fill in every value
# below, then `docker compose up -d --build`. This file itself is
# git-ignored and untouched by `git pull` — every deploy after this first
# one is just `git pull && docker compose up -d --build`.

# --- Domains (point both DNS A records at this VPS's IP first — Caddy
#     issues Let's Encrypt certificates automatically on first start) ---
DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com

# --- Database ---
DB_NAME=refurbinics
DB_USER=postgres
# Generate with: openssl rand -base64 24
DB_PASSWORD=change-me

# --- Backend (Express API) ---
# Generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d
# The public URL the frontend is actually served from (browser-facing),
# for CORS — should be https://DOMAIN above, once DNS/Caddy are live.
CLIENT_URL=https://yourdomain.com

# --- Frontend (baked into the static bundle at build time) ---
# The public URL the browser will reach the backend at — should be
# https://API_DOMAIN above.
VITE_API_URL=https://api.yourdomain.com/api
