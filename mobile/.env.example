# Copy this file to .env and point it at your backend.
#
# Note: unlike backend/.env and frontend/.env, this project's .gitignore does
# NOT exclude .env (only .env*.local) — so mobile/.env is currently tracked
# in git. That's fine as long as it only ever holds a non-secret API URL like
# below; if a real secret is ever added here, .gitignore should be updated
# to ignore .env too.

# Base URL of the backend API, including the /api prefix. Expo only exposes
# env vars prefixed with EXPO_PUBLIC_ to app code (see src/services/api-client.js),
# and — like Vite's VITE_ vars — it's baked in at build time.
#   - Expo Go / dev build on a physical device: http://<your-lan-ip>:5000/api
#     (must be your computer's LAN IP, not localhost — the phone is a
#     separate device on the network)
#   - Production build:                          https://<your-backend-domain>/api
EXPO_PUBLIC_API_URL=http://192.168.31.234:5000/api
