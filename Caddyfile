# Reverse proxy + automatic HTTPS (Let's Encrypt) for the whole stack.
# DOMAIN/API_DOMAIN come from .env — point their DNS A records at this
# VPS's IP before starting the stack, or Caddy can't issue certificates.
#
# Local testing without a real domain: set DOMAIN=localhost:8080 and
# API_DOMAIN=localhost:8081 in .env — Caddy serves plain HTTP for
# non-public hostnames instead of attempting ACME.

{$DOMAIN} {
	reverse_proxy frontend:8080
}

{$API_DOMAIN} {
	reverse_proxy backend:5000
}
